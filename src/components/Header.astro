---
const path = Astro.url.pathname;
import { comBase } from '../utils/url';
import Icon from '../components/Icon.astro';
---
<header class="border-b border-blue-950/10 bg-paper/95 backdrop-blur">
  <div class="container-page flex items-center justify-between gap-3 py-3 md:grid md:grid-cols-[auto_minmax(16rem,30rem)_auto]">
    <a href={comBase()} class="flex items-center gap-2 font-black text-forest-dark" aria-label="Página inicial do TeOrientaCalouro">
      <img src={comBase('icon.svg')} alt="" class="h-10 w-10" />
      <span class="leading-4">TeOrienta<br /><span class="text-forest">Calouro</span></span>
    </a>
    <div><label class="hidden md:block"> <span class="sr-only">Buscar no guia</span> <input data-search-open class="w-full rounded-xl border border-blue-950/15 bg-white px-4 py-2.5 text-sm shadow-sm placeholder:text-ink/55 focus:border-forest" type="search" placeholder="Busque uma dúvida, serviço ou setor" readonly aria-haspopup="dialog" /></label> <button data-search-open class="block rounded-full bg-white p-2.5 w-10 h-10 shadow-sm md:hidden" aria-label="Buscar no guia"><Icon nome="pesquisar" class="size-5" /></button></div>
    <nav aria-label="Navegação principal" class="order-2 flex items-center justify-end gap-3 text-sm font-bold md:order-3 md:gap-5">
      <a class:list={["hover:text-forest", path.includes('/guia') && 'text-forest']} href={comBase('guia/primeiros-passos')}>Guias</a>
      <a class:list={["hover:text-forest", path.includes('/mapa') && 'text-forest']} href={comBase('mapa')}>Mapa</a>
      <a class:list={["hover:text-forest", path.includes('/contatos') && 'text-forest']} href={comBase('contatos')}>Contatos</a>
    </nav>
  </div>
</header>
