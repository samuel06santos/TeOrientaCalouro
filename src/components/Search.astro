<dialog data-search-dialog class="m-auto w-[min(42rem,calc(100%-2rem))] rounded-2xl border border-emerald-950/15 bg-white p-0 shadow-2xl backdrop:bg-ink/40">
  <div class="p-5">
    <div class="flex items-center justify-between gap-4"><h2 class="text-xl font-extrabold text-forest-dark">Encontre uma orientação</h2><button data-search-close aria-label="Fechar busca" class="rounded-lg p-2 text-ink/70 hover:bg-paper">✕</button></div>
    <label class="mt-4 block"><span class="sr-only">Buscar no guia</span><input data-search-input class="w-full rounded-xl border border-emerald-950/20 px-4 py-3 text-lg" type="search" placeholder="Ex.: como acessar o SIGAA?" autocomplete="off" /></label>
    <p class="mt-3 text-sm text-ink/65">Busque por assunto, serviço ou uma dúvida do dia a dia.</p>
    <ul data-search-results class="mt-4 max-h-80 space-y-2 overflow-y-auto" aria-live="polite"></ul>
  </div>
</dialog>
<script>
  import Fuse from 'fuse.js';
  const dialog = document.querySelector<HTMLDialogElement>('[data-search-dialog]')!;
  const input = document.querySelector<HTMLInputElement>('[data-search-input]')!;
  const results = document.querySelector<HTMLUListElement>('[data-search-results]')!;
  let fuse: Fuse<{ titulo: string; resumo: string; tags: string[]; url: string }> | undefined;
  const escape = (text: string) => text.replace(/[&<>"']/g, (character) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[character]!));
  async function openSearch() {
    dialog.showModal(); input.focus();
    if (!fuse) fuse = new Fuse(await (await fetch('/search.json')).json(), { keys: ['titulo', 'resumo', 'tags'], threshold: 0.35 });
  }
  document.querySelectorAll('[data-search-open]').forEach((button) => button.addEventListener('click', openSearch));
  document.querySelector('[data-search-close]')?.addEventListener('click', () => dialog.close());
  input.addEventListener('input', () => {
    const query = input.value.trim();
    if (!query || !fuse) { results.innerHTML = ''; return; }
    const found = fuse.search(query).slice(0, 6).map(({ item }) => `<li><a class="block rounded-xl p-3 hover:bg-paper" href="${item.url}"><strong class="text-forest-dark">${escape(item.titulo)}</strong><span class="mt-1 block text-sm text-ink/70">${escape(item.resumo)}</span></a></li>`).join('');
    results.innerHTML = found || '<li class="rounded-xl bg-paper p-3 text-sm">Ainda não encontrei algo assim. Tente palavras como “matrícula”, “Wi-Fi” ou “auxílio”.</li>';
  });
</script>
