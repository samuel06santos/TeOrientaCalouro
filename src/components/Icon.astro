---
import { icon } from '@fortawesome/fontawesome-svg-core';
import {
  faArrowRight,
  faBookOpen,
  faBuildingColumns,
  faBusSimple,
  faCalendarDays,
  faCircleInfo,
  faClock,
  faGraduationCap,
  faGaugeHigh,
  faHeart,
  faIdCard,
  faLandmark,
  faLocationDot,
  faMagnifyingGlass,
  faMapLocationDot,
  faMoneyBillTransfer,
  faRoute,
  faShieldHeart,
  faShop,
  faTicket,
  faToilet,
  faTrainSubway,
  faUtensils,
  faVault,
  faWheelchairMove,
  faWifi,
} from '@fortawesome/free-solid-svg-icons';

// Mantemos um conjunto pequeno e nomeado para não enviar a biblioteca inteira ao navegador.
const icones = {
  alimentacao: faUtensils,
  banco: faBuildingColumns,
  biblioteca: faBookOpen,
  caixa: faVault,
  calendario: faCalendarDays,
  contato: faLandmark,
  dinheiro: faMoneyBillTransfer,
  estudante: faGraduationCap,
  horario: faClock,
  informacao: faCircleInfo,
  local: faLocationDot,
  mapa: faMapLocationDot,
  mobilidade: faBusSimple,
  passagem: faTicket,
  rota: faRoute,
  seguranca: faShieldHeart,
  suporte: faHeart,
  terminal: faTrainSubway,
  documento: faIdCard,
  comercio: faShop,
  banheiro: faToilet,
  acessibilidade: faWheelchairMove,
  wifi: faWifi,
  velocidade: faGaugeHigh,
  avancar: faArrowRight,
  pesquisar: faMagnifyingGlass,
} as const;

type NomeIcone = keyof typeof icones;
interface Props {
  nome: NomeIcone | string;
  classe?: string;
  rotulo?: string;
  class?: string;
}

const { nome, classe = '', rotulo, class: classeCss = '' } = Astro.props;
const definicao = icones[nome as NomeIcone] ?? faCircleInfo;
const svg = icon(definicao).html.join('');
---
<span
  class:list={['site-icon', classe, classeCss]}
  aria-hidden={rotulo ? undefined : 'true'}
  role={rotulo ? 'img' : undefined}
  aria-label={rotulo}
  set:html={svg}
/>

<style>
  .site-icon {
    display: inline-grid;
    place-items: center;
    line-height: 1;
  }

  .site-icon :global(svg) {
    width: 1em;
    height: 1em;
  }
</style>
