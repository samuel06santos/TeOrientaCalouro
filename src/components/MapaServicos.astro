---
import type { PontoServico } from '../data/mapa-servicos';

interface Props {
  id: string;
  pontos: PontoServico[];
  linha?: [number, number][];
  rotulo: string;
}

const { id, pontos, linha = [], rotulo } = Astro.props;
const idDados = `${id}-dados`;
---
<div class="overflow-hidden rounded-2xl border border-blue-950/10 bg-white shadow-sm">
  <div id={id} data-mapa-servicos data-dados={idDados} class="h-[28rem] w-full" aria-label={rotulo}></div>
</div>
<p class="mt-3 text-sm leading-6 text-ink/70">
  Use os botões do mapa ou <strong>Ctrl + rolagem</strong> para aproximar. As posições usam dados do OpenStreetMap; o botão de rota abre o Google Maps.
</p>
<script is:inline id={idDados} type="application/json" set:html={JSON.stringify({ pontos, linha })}></script>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import type { PontoServico } from '../data/mapa-servicos';

  type DadosMapa = { pontos: PontoServico[]; linha: [number, number][] };

  const corCategoria = (categoria: string) => {
    const categoriaNormalizada = categoria.toLocaleLowerCase('pt-BR');
    if (categoriaNormalizada.includes('restaurante') || categoriaNormalizada.includes('cantina') || categoriaNormalizada.includes('alimentação') || categoriaNormalizada.includes('lanche') || categoriaNormalizada.includes('café') || categoriaNormalizada.includes('praça')) return '#d5263d';
    if (categoriaNormalizada.includes('biblioteca')) return '#07559b';
    if (categoriaNormalizada.includes('banco') || categoriaNormalizada.includes('caixa')) return '#7048a8';
    if (categoriaNormalizada.includes('parada')) return '#d5263d';
    return '#062d5d';
  };

  document.querySelectorAll<HTMLElement>('[data-mapa-servicos]:not([data-carregado])').forEach((elemento) => {
    elemento.dataset.carregado = 'true';
    const dadosElemento = document.getElementById(elemento.dataset.dados || '');
    const dados: DadosMapa = JSON.parse(dadosElemento?.textContent || '{"pontos":[],"linha":[]}');
    const mapa = L.map(elemento, { scrollWheelZoom: false, zoomControl: true }).setView([-1.4733, -48.4537], 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; OpenStreetMap contributors',
    }).addTo(mapa);

    elemento.addEventListener('wheel', (evento) => {
      if (evento.ctrlKey || evento.metaKey) mapa.scrollWheelZoom.enable();
      else mapa.scrollWheelZoom.disable();
    }, { capture: true, passive: true });

    const limites: [number, number][] = [];
    dados.pontos.forEach((ponto) => {
      limites.push([ponto.lat, ponto.lng]);
      const cor = corCategoria(ponto.categoria);
      const marcador = L.circleMarker([ponto.lat, ponto.lng], {
        radius: ponto.categoria === 'Parada do Circular' ? 7 : 8,
        color: '#ffffff',
        fillColor: cor,
        fillOpacity: 1,
        weight: 2,
      }).addTo(mapa);

      const popup = document.createElement('div');
      const titulo = document.createElement('strong');
      titulo.textContent = ponto.nome;
      const descricao = document.createElement('p');
      descricao.textContent = ponto.descricao;
      descricao.style.margin = '0.35rem 0';
      popup.append(titulo, descricao);
      if (ponto.horario) {
        const horario = document.createElement('p');
        horario.textContent = ponto.horario;
        horario.style.margin = '0.35rem 0';
        popup.append(horario);
      }
      const rota = document.createElement('a');
      rota.href = ponto.rota;
      rota.target = '_blank';
      rota.rel = 'noreferrer';
      rota.textContent = 'Abrir rota no Google Maps';
      popup.append(rota);
      marcador.bindPopup(popup);
    });

    if (dados.linha.length > 1) {
      dados.linha.forEach((coordenada) => limites.push(coordenada));
      L.polyline(dados.linha, { color: '#07559b', weight: 5, opacity: 0.8, dashArray: '10 8' }).addTo(mapa);
    }

    if (limites.length) mapa.fitBounds(limites, { padding: [28, 28], maxZoom: 16 });
  });
</script>
