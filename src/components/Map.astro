---
import { locais } from '../data/locais';
---
<div class="overflow-hidden rounded-2xl border border-blue-950/10 bg-white shadow-sm">
  <div id="mapa-ufpa" class="h-96 w-full" aria-label="Mapa com locais importantes da UFPA"></div>
</div>
<p class="mt-3 text-sm text-ink/70">Use os botões do mapa ou <strong>Ctrl + rolagem</strong> para aproximar e afastar.</p>
<script is:inline id="mapa-dados" type="application/json" set:html={JSON.stringify(locais)}></script>
<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  type MapaLocal = { nome: string; lat: number; lng: number; descricao: string; rota: string };
  const locais: MapaLocal[] = JSON.parse(document.querySelector('#mapa-dados')?.textContent || '[]');
  const map = L.map('mapa-ufpa', { scrollWheelZoom: false, zoomControl: true }).setView([-1.4733, -48.4537], 15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19, attribution: '&copy; OpenStreetMap contributors' }).addTo(map);
  map.getContainer().addEventListener('wheel', (event) => { if (event.ctrlKey || event.metaKey) map.scrollWheelZoom.enable(); else map.scrollWheelZoom.disable(); }, { capture: true, passive: true });
  locais.forEach((local) => L.circleMarker([local.lat, local.lng], { radius: 8, color: '#062d5d', fillColor: '#d5263d', fillOpacity: 1, weight: 2 }).addTo(map).bindPopup(`<strong>${local.nome}</strong><br>${local.descricao}<br><a href="${local.rota}" target="_blank" rel="noreferrer">Abrir no Google Maps</a>`));
</script>
