---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro'; import Header from '../../components/Header.astro'; import Footer from '../../components/Footer.astro'; import Search from '../../components/Search.astro';
import { comBase } from '../../utils/url';
export async function getStaticPaths() { const guias = await getCollection('guias'); return guias.map((guia) => ({ params: { slug: guia.id }, props: { guia } })); }
const { guia } = Astro.props;
const { Content } = await render(guia);
---
<BaseLayout title={`${guia.data.titulo} | TeOrientaCalouro`} description={guia.data.resumo}>
  <Header /><main id="conteudo" class="container-page py-10 sm:py-14"><div class="max-w-3xl"><a href={comBase('guias')} class="font-bold text-forest underline underline-offset-4">← Todos os guias</a><p class="guide-index mt-8" aria-hidden="true">{guia.data.icone}</p><h1 class="mt-3 text-4xl font-black tracking-tight text-forest-dark sm:text-5xl">{guia.data.titulo}</h1><p class="mt-4 text-xl leading-8 text-ink/75">{guia.data.resumo}</p><div class="mt-7 rounded-xl border border-blue-950/10 bg-blue-50 p-4 text-sm"><strong>Fonte principal:</strong> <a class="font-bold text-forest underline" href={guia.data.fonte} target="_blank" rel="noreferrer">{guia.data.fonteNome} ↗</a><span class="block mt-1 text-ink/70">Última revisão deste guia: {guia.data.atualizadoEm}.</span></div><article class="prose-guide"><Content /></article><div class="mt-10 rounded-2xl bg-ink p-6 text-white"><h2 class="text-xl font-extrabold">Encontrou algo que precisa de atualização?</h2><p class="mt-2 text-white/80">Este guia é uma camada de orientação. Confirme as informações na fonte oficial e comunique sua coordenação ou o setor responsável quando necessário.</p></div></div></main><Footer /><Search />
</BaseLayout>
