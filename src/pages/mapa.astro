---
import BaseLayout from '../layouts/BaseLayout.astro'; import Header from '../components/Header.astro'; import Footer from '../components/Footer.astro'; import Search from '../components/Search.astro'; import Map from '../components/Map.astro'; import { locais } from '../data/locais';
---
<BaseLayout title="Mapa do Campus | TeOrientaCalouro" description="Pontos de referência no Campus Guamá da UFPA.">
  <Header /><main id="conteudo" class="container-page py-12"><p class="eyebrow">Campus Guamá</p><h1 class="mt-2 text-4xl font-black text-forest-dark">Encontre seu caminho</h1><p class="mt-3 max-w-2xl leading-7 text-ink/75">Os pontos de referência abaixo usam dados cartográficos do OpenStreetMap. Para navegar, abra o destino no Google Maps.</p><div class="mt-7"><Map /></div><section class="mt-9"><h2 class="text-2xl font-black text-forest-dark">Pontos no mapa</h2><div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">{locais.map((local) => <article class="card"><p class="text-sm font-bold text-forest">{local.categoria} · Setor {local.setor}</p><h3 class="mt-1 text-lg font-extrabold text-forest-dark">{local.nome}</h3><p class="mt-2 leading-6 text-ink/70">{local.descricao}</p><a href={local.rota} target="_blank" rel="noreferrer" class="mt-3 inline-block font-bold text-forest underline underline-offset-2">Abrir no Google Maps ↗</a></article>)}</div></section><p class="mt-8 rounded-xl bg-red-50 p-4 text-sm leading-6 text-red-950">Os pontos são referências de orientação. Confira a sinalização e os canais oficiais da UFPA, especialmente em dias de eventos ou mudanças de acesso.</p></main><Footer /><Search />
</BaseLayout>
